    const currencyFilter = document.getElementById("currencyFilter");
    const sortFilter = document.getElementById("sortFilter");

    let selectedKey = "";

    function normalizeAmount(value) {
      return Number(String(value).replace(/,/g, ""));
    }

    function getFlag(country) {
      return flagMap[country] || "🌍";
    }

    function getCountryList() {
      return [...new Set(data.map(item => item.country))].sort((a, b) => a.localeCompare(b));
    }

    function getCurrencyList() {
      return [...new Set(data.map(item => item.currency))].sort((a, b) => a.localeCompare(b));
    }

    function populateFilters() {
      getCountryList().forEach(country => {
        const option = document.createElement("option");
        option.value = country;
        option.textContent = `${getFlag(country)} ${country}`;
        countryFilter.appendChild(option);
      });

      getCurrencyList().forEach(currency => {
        const option = document.createElement("option");
        option.value = currency;
        option.textContent = currency;
        currencyFilter.appendChild(option);
      });
    }

    function updateHeroStats() {
      document.getElementById("totalDestinations").textContent = data.length;
      document.getElementById("totalCountries").textContent = getCountryList().length;
      document.getElementById("totalCurrencies").textContent = getCurrencyList().length;
    }

    function getBaseFilteredRows() {
      const value = searchInput.value.trim().toLowerCase();
      const selectedCountry = countryFilter.value;
      const selectedCurrency = currencyFilter.value;
      const sortValue = sortFilter.value;

      let filtered = data.filter(item => {
        const matchesSearch =
          item.country.toLowerCase().includes(value) ||
          item.city.toLowerCase().includes(value) ||
          item.currency.toLowerCase().includes(value) ||
          String(item.amount).toLowerCase().includes(value);

        const matchesCountry = !selectedCountry || item.country === selectedCountry;
        const matchesCurrency = !selectedCurrency || item.currency === selectedCurrency;

        return matchesSearch && matchesCountry && matchesCurrency;
      });

      if (sortValue === "amount-desc") {
        filtered.sort((a, b) => normalizeAmount(b.amount) - normalizeAmount(a.amount));
      } else if (sortValue === "amount-asc") {
        filtered.sort((a, b) => normalizeAmount(a.amount) - normalizeAmount(b.amount));
      } else if (sortValue === "country-asc") {
        filtered.sort((a, b) => a.country.localeCompare(b.country));
      } else if (sortValue === "city-asc") {
        filtered.sort((a, b) => a.city.localeCompare(b.city));
      }

      return filtered;
    }

    function renderCards(rows) {
      cardsContainer.innerHTML = "";
      const cardsData = rows.slice(0, 18);
      cardCount.textContent = `${rows.length} תוצאות`;

      cardsData.forEach(item => {
        const key = `${item.country}__${item.city}`;
        const card = document.createElement("article");
        card.className = `city-card ${selectedKey === key ? "active" : ""}`;
        card.innerHTML = `
          <div class="city-media" data-city="${item.city}">
            <div class="city-flag">${getFlag(item.country)}</div>
            <div class="city-badge">${item.currency} · ${item.amount}</div>
          </div>
          <div class="city-body">
            <div class="city-title">
              <div>
                <h4>${item.city}</h4>
                <small>${item.country}</small>
              </div>
              <span class="pill">${item.amount}</span>
            </div>
            <div class="city-meta">
              <span>מטבע: ${item.currency}</span>
              <span>דגל: ${getFlag(item.country)}</span>
              <span>יעד: ${item.city === "כל המדינה" ? "כל המדינה" : item.city}</span>
            </div>
          </div>
        `;

        card.addEventListener("click", () => {
          selectedKey = selectedKey === key ? "" : key;
          renderAll();
        });

        cardsContainer.appendChild(card);
      });
    }

    function renderTable(rows) {
      tableBody.innerHTML = "";

      rows.forEach(item => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>
            <div class="country-cell">
              <span class="flag-chip">${getFlag(item.country)}</span>
              <span>${item.country}</span>
            </div>
          </td>
          <td>${item.city}</td>
          <td>${item.currency}</td>
          <td class="amount">${item.amount}</td>
        `;
        tableBody.appendChild(tr);
      });

      statsText.textContent = `סה״כ תוצאות: ${rows.length}`;
      summaryText.textContent = rows.length === data.length
        ? "המערכת מציגה את כל היעדים כרגע"
        : `מוצגות ${rows.length} תוצאות לאחר סינון`;

      if (selectedKey) {
        const [country, city] = selectedKey.split("__");
        selectedText.textContent = `נבחר יעד: ${country} / ${city}`;
      } else {
        selectedText.textContent = "לא נבחר יעד ספציפי";
      }

      noResults.style.display = rows.length ? "none" : "block";
    }

    function renderAll() {
      const baseRows = getBaseFilteredRows();
      renderCards(baseRows);

      let tableRows = baseRows;
      if (selectedKey) {
        tableRows = baseRows.filter(item => `${item.country}__${item.city}` === selectedKey);
      }

      renderTable(tableRows);
    }

    [searchInput, countryFilter, currencyFilter, sortFilter].forEach(control => {
      control.addEventListener("input", renderAll);
      control.addEventListener("change", renderAll);
    });

    populateFilters();
    updateHeroStats();
    renderAll();
