<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>קצובות לינה בעולם</title>
  <meta name="description" content="מיני־סייט פרימיום לחיפוש קצובות לינה לפי מדינה, עיר ומטבע" />
  <style>
    :root {
      --bg: #07111f;
      --bg-soft: #0f1b2d;
      --card: rgba(255,255,255,0.08);
      --card-strong: rgba(255,255,255,0.12);
      --line: rgba(255,255,255,0.12);
      --text: #f4f7fb;
      --muted: #b8c2d3;
      --accent: #8ec5ff;
      --accent-2: #d9efff;
      --success: #8ff0b3;
      --shadow: 0 20px 60px rgba(0,0,0,0.35);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top right, rgba(110,168,255,0.22), transparent 30%),
        radial-gradient(circle at top left, rgba(173,216,255,0.14), transparent 22%),
        linear-gradient(180deg, #08111e 0%, #0b1628 48%, #09111c 100%);
      min-height: 100vh;
    }

    .shell {
      width: min(1380px, calc(100% - 28px));
      margin: 0 auto;
      padding: 24px 0 48px;
    }

    .hero {
      position: relative;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 34px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.05)),
        linear-gradient(135deg, #0c1830, #12233d 55%, #0b1829);
      box-shadow: var(--shadow);
      padding: 34px;
      margin-bottom: 22px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.25fr 0.85fr;
      gap: 24px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.09);
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--accent-2);
      font-size: 13px;
      margin-bottom: 14px;
    }

    h1 {
      margin: 0;
      font-size: clamp(32px, 5vw, 58px);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .hero p {
      color: var(--muted);
      font-size: 16px;
      line-height: 1.8;
      margin: 14px 0 0;
      max-width: 760px;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 26px;
    }

    .stat {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.11);
      border-radius: 16px;
      padding: 16px;
      backdrop-filter: blur(8px);
    }

    .stat .label {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 6px;
    }

    .stat .value {
      display: block;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .hero-panel {
      background: linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.06));
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 28px;
      padding: 20px;
      backdrop-filter: blur(10px);
    }

    .hero-panel h2 {
      margin: 0 0 8px;
      font-size: 20px;
    }

    .hero-panel p {
      margin: 0 0 14px;
      font-size: 14px;
      line-height: 1.7;
    }

    .hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .hero-tags span {
      padding: 10px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.09);
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 13px;
      color: #e8f1ff;
    }

    .toolbar {
      display: grid;
      grid-template-columns: 1.5fr repeat(3, minmax(0, 0.6fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .control {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.07);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 0 16px;
      min-height: 60px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .control span {
      font-size: 18px;
      opacity: 0.9;
    }

    .control input, .control select {
      width: 100%;
      background: transparent;
      border: 0;
      outline: none;
      color: var(--text);
      font-size: 15px;
      font-family: inherit;
    }

    .control input::placeholder { color: #b9c3d4; }
    .control select option { color: #111827; }

    .layout {
      display: grid;
      grid-template-columns: 390px 1fr;
      gap: 18px;
      align-items: start;
    }

    .panel, .table-panel {
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--line);
      border-radius: 28px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
      overflow: hidden;
    }

    .panel-head, .table-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 18px 20px;
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
    }

    .panel-head h3, .table-head h3 {
      margin: 0;
      font-size: 18px;
    }

    .panel-head small, .table-head small {
      color: var(--muted);
      font-size: 13px;
    }

    .cards {
      padding: 14px;
      display: grid;
      gap: 14px;
      max-height: 920px;
      overflow: auto;
    }

    .city-card {
      position: relative;
      overflow: hidden;
      border-radius: 22px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.1);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      cursor: pointer;
    }

    .city-card:hover,
    .city-card.active {
      transform: translateY(-2px);
      border-color: rgba(142,197,255,0.45);
      background: rgba(255,255,255,0.1);
    }

    .city-media {
      position: relative;
      height: 180px;
      overflow: hidden;
      background: linear-gradient(135deg, #23395d, #101c2f 55%, #0f172a);
    }

    .city-media::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,0.16), transparent 25%),
        radial-gradient(circle at 80% 30%, rgba(142,197,255,0.22), transparent 30%),
        radial-gradient(circle at 60% 80%, rgba(255,255,255,0.08), transparent 28%);
    }

    .city-media::after {
      content: attr(data-city);
      position: absolute;
      left: 18px;
      bottom: 14px;
      font-size: 24px;
      font-weight: 800;
      color: rgba(255,255,255,0.22);
      letter-spacing: 0.03em;
      pointer-events: none;
      max-width: 70%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .city-flag {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(7,17,31,0.72);
      backdrop-filter: blur(8px);
      display: grid;
      place-items: center;
      font-size: 24px;
      border: 1px solid rgba(255,255,255,0.18);
      box-shadow: 0 10px 25px rgba(0,0,0,0.28);
      z-index: 1;
    }

    .city-badge {
      position: absolute;
      left: 12px;
      top: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(7,17,31,0.78);
      border: 1px solid rgba(255,255,255,0.16);
      font-size: 12px;
      color: #eff6ff;
      z-index: 1;
    }

    .city-body { padding: 16px; }

    .city-title {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .city-title h4 {
      margin: 0;
      font-size: 20px;
    }

    .city-title small {
      display: block;
      color: var(--muted);
      margin-top: 4px;
      font-size: 13px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 70px;
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(143,240,179,0.12);
      color: var(--success);
      border: 1px solid rgba(143,240,179,0.2);
      font-weight: 700;
      font-size: 13px;
      white-space: nowrap;
    }

    .city-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .city-meta span {
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      font-size: 12px;
      color: #e2e8f0;
    }

    .table-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 20px 0;
      color: var(--muted);
      font-size: 14px;
    }

    .table-wrap {
      padding: 14px 14px 18px;
      overflow: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 900px;
      overflow: hidden;
      border-radius: 18px;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: rgba(11,22,40,0.96);
      color: #f4f7fb;
      font-weight: 700;
      font-size: 13px;
      padding: 16px 14px;
      text-align: right;
      border-bottom: 1px solid rgba(255,255,255,0.12);
    }

    tbody td {
      padding: 16px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      color: #edf3fb;
      font-size: 14px;
    }

    tbody tr:hover {
      background: rgba(255,255,255,0.05);
    }

    .country-cell {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
    }

    .flag-chip {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 17px;
      flex: 0 0 auto;
    }

    .amount {
      font-weight: 800;
      color: #9df5c6;
      letter-spacing: 0.01em;
    }

    .no-results {
      display: none;
      padding: 46px 24px 54px;
      text-align: center;
      color: var(--muted);
    }

    .no-results strong {
      display: block;
      font-size: 22px;
      color: var(--text);
      margin-bottom: 8px;
    }

    .footer-note {
      color: #9eb0c9;
      text-align: center;
      font-size: 13px;
      margin-top: 18px;
      opacity: 0.9;
    }

    @media (max-width: 1180px) {
      .layout { grid-template-columns: 1fr; }
      .cards { grid-template-columns: repeat(2, minmax(0,1fr)); max-height: none; }
    }

    @media (max-width: 980px) {
      .hero-grid, .toolbar { grid-template-columns: 1fr; }
    }

    @media (max-width: 760px) {
      .shell { width: min(100% - 18px, 100%); padding-top: 14px; }
      .hero { padding: 22px; border-radius: 26px; }
      .hero-stats { grid-template-columns: 1fr; }
      .cards { grid-template-columns: 1fr; }
      .panel, .table-panel { border-radius: 22px; }
    }
  </style>
</head>
